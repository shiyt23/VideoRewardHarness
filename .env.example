# Copy this to .env (or `export` directly in your shell) and fill in real values.
# `.env` is gitignored; don't commit credentials.

# ---- Required: Orchestrator (Vertex AI Gemini) ----
# Service-account JSON for Vertex AI. Get one from
# console.cloud.google.com -> IAM -> Service Accounts.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# GCP project + region tied to the service account above.
GEMINI_PROJECT=your-vertexai-project-id
GEMINI_LOCATION=global   # or us-central1 / europe-west4

# ---- Optional: Hugging Face (only if downloading gated datasets) ----
# Needed for TIGER-Lab/EditReward-Bench. Set this OR run `huggingface-cli login`.
# HF_TOKEN=hf_xxx

# ---- Optional: override the score-guidelines path ----
# Defaults to <repo>/score-guidelines/. Only set this if you've moved the
# templates or are running the package from an unusual install layout.
# REWARDHARNESS_TEMPLATES_DIR=/absolute/path/to/score-guidelines

# ---- Optional: swap in a different Sub-Agent VLM ----
# The OpenAI-compatible model id sent to vLLM /v1/chat/completions.
# Must match what your endpoint reports at /v1/models. Defaults to
# Qwen2.5-VL-7B-Instruct (the paper config).
# REWARDHARNESS_SUBAGENT_MODEL=Qwen2.5-VL-7B-Instruct

# ---- Optional: tune the vLLM launcher (scripts/serve_vllm_multi.sh) ----
# Defaults boot 4 endpoints (NUM_GPUS=4 × ENDPOINTS_PER_GPU=1).
# NUM_GPUS=4
# ENDPOINTS_PER_GPU=1
# BASE_PORT=8000
# GPU_MEM=0.85                  # passed to --gpu-memory-utilization
# MAX_MODEL_LEN=16384
# VLLM_MODEL_PATH=Qwen/Qwen2.5-VL-7B-Instruct
# VLLM_PYTHON=/path/to/venv/bin/python   # absolute python if PATH-resolved one is wrong

# ---- Required when using scripts/sbatch_vllm.sh ----
# RH_ROOT is the absolute path to your RewardHarness checkout. The sbatch
# wrapper fails fast if this isn't set so the script can't accidentally
# run against the template /path/to/your/... paths shipped in v0.1.x.
# RH_ROOT=/abs/path/to/your/reward-harness-checkout
# SLURM_NODES_DIR=$RH_ROOT/results/slurm_nodes   # override only if you want hostname pointers elsewhere

# ---- Optional: vLLM env-pin override (for non-BCM clusters) ----
# scripts/serve_vllm_multi.sh and start_vllm_remote.sh pin SLURM/CUDA paths
# for Compute Canada's Bright Cluster Manager layout. On vanilla Ubuntu/RHEL,
# set RH_SKIP_ENV_PIN=1 to disable that stanza; or override the prefixes.
# RH_SKIP_ENV_PIN=1
# SLURM_PREFIX=/opt/slurm
# CUDA_LIBS=/usr/local/cuda/lib64

# ---- Optional: route Gemini through a hosted gateway ----
# Used by vanilla/gemini_bench_*.py instead of direct Vertex AI. Unset both
# to skip this path entirely (the default — direct Vertex AI auth is used).
# GEMINI_GATEWAY_BASE_URL=https://your-gateway.example.com/v1
# GEMINI_GATEWAY_API_KEY=your-gateway-key

# ---- Optional: Claude baselines (vanilla/bench_{claude,genaibench,imagenhub}.py) ----
# OpenAI-compatible Claude proxy (LiteLLM, anthropic-bridge, etc.). Defaults
# point at a dead localhost demo proxy — set these to reproduce the paper's
# Claude-Sonnet-4.5 / Haiku-4.5 / Opus-4.6 baseline rows.
# CLAUDE_API_BASE_URL=https://your-claude-proxy.example.com/v1
# CLAUDE_API_KEY=your-claude-key
